@page "/"
@using Bildur.DataAccess
@inject ImageService _imageService
@inject IJSRuntime JS

@attribute [Authorize]

<PageTitle>Index</PageTitle>

<h1>Bildur AS Bildesystem™</h1>

<MudGrid Style="max-width: 500px">
    <MudItem md="12">
        <MudStack Row Wrap="Wrap.Wrap" Spacing="8" AlignItems="AlignItems.Center">

            <MudFileUpload @ref="@_fileUploadImages"
                           @bind-Files="_filesImages"
                           Accept=".png, .jpg, .tiff"
                           AppendMultipleFiles
                           MaximumFileCount="100">
                <CustomContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="@context.OpenFilePickerAsync"
                               StartIcon="@Icons.Material.Filled.CloudUpload">
                        Velg bilder
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        </MudStack>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudExpansionPanels Elevation="0">
                    <MudExpansionPanel Class="bold" Text="@($"({_files.Count}) bilder")" Expanded="false">
                        @if (_files.Any())
                        {
                            <MudList T="IBrowserFile" Dense="true">
                                @foreach (var file in _files)
                                {
                                    <MudListItem T="IBrowserFile" Value="file" @key="@file">
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="1" Class="w-100">
                                            <MudText>@file.Name (@($"{file.Size / 1024d:N1} kB"))</MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Color="Color.Default"
                                                           Size="Size.Small"
                                                           Disabled="_uploading"
                                                           aria-label="Remove file"
                                                           OnClick="@(() => RemoveFileFromUploadsAsync(file))" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">Ingen bilder valgt.</MudText>
                        }
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="!_files.Any() || _uploading"
                           OnClick="UploadFilesAsync"
                           StartIcon="@Icons.Material.Filled.CloudUpload">
                    Last opp
                </MudButton>

                @if (_uploading || _progress > 0)
                {
                    <MudProgressLinear Color="Color.Primary"
                                       Value="_progress"
                                       Indeterminate="_uploading && _files.Count == 0" />
                    <MudText Typo="Typo.caption">@_statusText</MudText>
                }
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem>
        <MudCarousel ArrowsColor="@Color.Primary" Style="height:400px; margin-top: 50px; min-width: 700px; max-width: 100vw" AutoCycle="false" TData="object">
        @foreach (var fileContent in UploadedFiles)
        {
            <MudCarouselItem>
                    <div class="d-flex" style="height:100%">
                        <MudImage class="mx-auto my-auto" Src=@("data:" + fileContent.ImageType + ";base64, " + fileContent.base64String) style=" object-fit: scale-down !important; width: 100%; height: 100%" />
                        <MudIconButton OnClick="() => DownloadImage(fileContent.ID)" Color="@Color.Info" Icon="@Icons.Material.Filled.Download" Variant="Variant.Outlined" Style=" position: absolute; top: 20px; right: 50px"></MudIconButton>
                        <MudIconButton OnClick="async () => await DeleteImage(fileContent.ID)" Color="@Color.Error" Icon="@Icons.Material.Filled.Delete" Variant="Variant.Outlined" Style=" position: absolute; top: 20px; right: 10px"></MudIconButton>
                    </div>
            </MudCarouselItem>
        }
        </MudCarousel>
    </MudItem>
</MudGrid>
@code
{
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<IBrowserFile> _filesMultiple = [];
    private IBrowserFile? _filesPDF;
    private IReadOnlyList<IBrowserFile> _filesImages = [];
    private IList<IBrowserFile> _files => (_filesMultiple ?? Enumerable.Empty<IBrowserFile>())
        .Concat(_filesPDF != null ? new[] { _filesPDF } : Enumerable.Empty<IBrowserFile>())
        .Concat(_filesImages ?? Enumerable.Empty<IBrowserFile>())
        .ToList();

    private MudFileUpload<IReadOnlyList<IBrowserFile>> _fileUploadMultiple = default!;
    private MudFileUpload<IBrowserFile> _fileUploadPDF = default!;
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _fileUploadImages = default!;

    private bool _uploading;
    private int _progress;
    private string _statusText = "Venter på bilder.";

    private IEnumerable<Image> UploadedFiles = [];

    private async Task UploadFilesAsync()
    {
        if (!_files.Any())
        {
            _statusText = "Ingen filer å laste opp.";
            return;
        }

        // Create a snapshot of the files to avoid altering the collection during iteration
        var filesSnapshot = _files.ToList();

        _uploading = true;
        _progress = 0;
        _statusText = "Laster opp...";
        
        var sub = await GetSubClaim();

        var total = filesSnapshot.Count;
        for (var index = 0; index < total; index++)
        {
            var file = filesSnapshot[index];
            var stream = file.OpenReadStream(14000000);
            byte[] byteArrayContent = new byte[stream.Length];
            var result = 0;
            while (result < stream.Length)
            {
                result = result + await stream.ReadAsync(byteArrayContent, result, (int)stream.Length - result);
            }
            var fileObject = new Image()
            {
                Content = byteArrayContent,
                FileName = file.Name,
                ImageType = file.ContentType,
                Size = (int)file.Size,
                UploadTime = DateTime.Now,
                Owner = sub
            };
            await _imageService.InsertImageAsync(fileObject);
            _progress = (int)Math.Round((index + 1d) / total * 100);
            _statusText = index + 1 == total ? "Opplastning ferdig." : $"Laster opp {index + 1} av {total}...";

            // In case the variables aren't disposed of correctly
            fileObject.Content = new byte[0];
            byteArrayContent = new byte[0];

            await RemoveFileFromUploadsAsync(file);
            await InvokeAsync(StateHasChanged);
        }
        await LoadImagesAsync();
        _uploading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteImage(int id)
    {
        await _imageService.DeleteImageAsync(id);
        await LoadImagesAsync();
    }

    private async void DownloadImage(int id)
    {
        var image = UploadedFiles.Where(x => x.ID == id).First();
        await JS.InvokeVoidAsync(
          "downloadFromByteArray", image.base64String, "image." + image.ImageType.Split("image/")[1], image.ImageType);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadImagesAsync();

        System.Runtime.GCSettings.LargeObjectHeapCompactionMode = System.Runtime.GCLargeObjectHeapCompactionMode.CompactOnce;
    }
    private async Task RemoveFileFromUploadsAsync(IBrowserFile file)
    {
        var fileUploads = new object[] { _fileUploadMultiple, _fileUploadPDF, _fileUploadImages };

        foreach (var fileUpload in fileUploads)
        {
            if (fileUpload is MudFileUpload<IReadOnlyList<IBrowserFile>> multipleUpload && await multipleUpload.RemoveFileAsync(file))
            {
                return; // File removed from multiple files upload
            }

            if (fileUpload is MudFileUpload<IBrowserFile> singleUpload && await singleUpload.RemoveFileAsync(file))
            {
                return; // File removed from single file upload
            }
        }
    }

    private async Task LoadImagesAsync()
    {
        var images = await _imageService.GetAllImagesForUserAsync(await GetSubClaim());
        foreach (var image in images)
        {
            // Instead of duplicating data, convert to base64 string and remove the byte array to free up memory
            // The String is less memory efficient, but is used to both display and download the image
            image.base64String = Convert.ToBase64String(image.Content);
            image.Content = new byte[0];
        }
        UploadedFiles = images.ToArray();
    }

    private async Task<string> GetSubClaim()
    {
        var authState = await AuthState!;
        // Shortname for this claim is 'sub'
        return authState.User.Claims.Where(x => x.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier").First().Value;
    } 
}